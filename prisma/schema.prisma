// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  images    Image[]
  reports   Report[]
  videos      Video[]
  towerVideos TowerVideo[]
  createdAt   DateTime @default(now())
}

model Image {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  url          String
  thumbnailUrl String?
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
}

model Report {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  url       String
  towerId   String
  type      String   // 'thermal' or 'findings'
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Video {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  url          String
  thumbnailKey String?
  thumbnailUrl String?
  towerFromId  String
  towerToId    String
  type         String   // 'rgb' or 'thermal'
  filename     String
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([towerFromId, towerToId, type])
}

model TowerVideo {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  url          String
  thumbnailKey String?
  thumbnailUrl String?
  towerId      String
  type         String   // 'rgb' or 'thermal'
  filename     String
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([towerId, type])
}
